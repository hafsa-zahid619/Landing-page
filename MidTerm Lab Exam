
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My eStore | Hub</title>
  
  <style>
    /* Core Reset */
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; background: #fff; color: #1a1a1a; overflow-x: hidden; }

    /* Header & Nav */
    header { display: flex; align-items: center; justify-content: space-between; padding: 12px 5%; border-bottom: 1px solid #eee; position: sticky; top: 0; background: white; z-index: 1000; }
    .header-left { display: flex; align-items: center; gap: 15px; }
    .menu-icon { font-size: 24px; cursor: pointer; }
    .logo { font-size: 26px; font-weight: bold; color: #004080; }
    .search-bar { flex: 1; display: flex; margin: 0 40px; }
    .search-bar input { width: 100%; max-width: 500px; padding: 10px 20px; border: 1px solid #333; border-radius: 25px 0 0 25px; outline: none; }
    .search-bar button { padding: 10px 25px; border: 1px solid #333; background: #0066ff; color: white; border-radius: 0 25px 25px 0; cursor: pointer; font-weight: bold; }
    .top-nav a { text-decoration: none; color: #333; margin-left: 15px; font-size: 14px; font-weight: 500; }

    /* Sidebar & Overlay */
    .side-nav { height: 100%; width: 0; position: fixed; z-index: 2100; top: 0; left: 0; background: #fff; overflow-x: hidden; transition: 0.3s; padding-top: 60px; box-shadow: 2px 0 10px rgba(0,0,0,0.1); }
    .side-nav a { padding: 12px 32px; text-decoration: none; font-size: 16px; color: #333; display: block; }
    .overlay { display: none; position: fixed; width: 100%; height: 100%; top: 0; left: 0; background: rgba(0,0,0,0.5); z-index: 2000; }

    /* Hero Section */
    .hero { width: 100%; height: 420px; background: url('images/background.jpg') center/cover; display: flex; align-items: center; padding-left: 8%; }
    .hero-text { background: rgba(0,0,0,0.75); padding: 35px; border-radius: 12px; max-width: 480px; color: white; }
    .hero-text h1 { font-size: 34px; margin-bottom: 10px; color: white; }
    .hero-text p { font-size: 18px; margin-bottom: 20px; color: white; }
    .sign-in-btn { background: white; color: #1a1a1a; border: none; padding: 12px 30px; border-radius: 25px; font-weight: bold; cursor: pointer; }

    /* Grids & Cards */
    .categories-container { padding: 50px 5%; }
    .section-title { font-size: 24px; margin-bottom: 25px; }
    .categories-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; }

    /* Consistent Category Image Sizing */
    .img-box { 
      background: #f3f3f3; 
      border-radius: 15px; 
      width: 100%;
      aspect-ratio: 1/1; 
      display: flex; 
      align-items: center; 
      justify-content: center; 
      overflow: hidden; 
      margin-bottom: 10px; 
      padding: 15px; 
    }

    .img-box img { 
      width: 100%; 
      height: 100%; 
      object-fit: contain; 
      transition: transform 0.3s ease; 
    }

    .category-item p { text-align: left; font-weight: 500; font-size: 15px; }
    .category-item:hover .img-box img { transform: scale(1.08); }

    /* Dynamic Card Styling */
    .dynamic-card { border: 1px solid #f0f0f0; padding: 15px; border-radius: 15px; text-align: center; }
    .product-price { font-weight: bold; font-size: 18px; color: #0066ff; margin: 10px 0; }
    .quick-view-btn { background: #1a1a1a; color: white; border: none; padding: 8px 18px; border-radius: 20px; cursor: pointer; }

    /* CTA Section (Shopping Made Easy) */
    .cta-section { padding: 40px 5%; }
    .cta-banner { background: #f7f7f7; border-radius: 15px; padding: 40px; display: flex; justify-content: space-between; align-items: center; border: 1px solid #eee; }
    .start-now-pill { background-color: #1a1a1a; color: white; border: none; padding: 12px 35px; border-radius: 30px; font-weight: bold; font-size: 16px; cursor: pointer; transition: 0.2s ease; }
    .start-now-pill:hover { background-color: #333; transform: scale(1.05); }

    /* Accessories Hero (Black Section) */
    .accessories-hero { background-color: #1a1a1a; color: white; padding: 80px 5%; display: flex; align-items: center; justify-content: space-between; overflow: hidden; }
    .acc-text h2 { font-size: 40px; margin-bottom: 15px; }
    .acc-text p { color: #aaa; margin-bottom: 25px; }
    .shop-now-fixed { background: transparent; color: white; border: 2px solid white; padding: 12px 30px; border-radius: 25px; font-weight: bold; cursor: pointer; transition: 0.3s; }
    .shop-now-fixed:hover { background: white; color: #1a1a1a; }
    .acc-images { display: flex; gap: 25px; }

    .acc-card-fixed {
      background: white; border-radius: 20px; width: 200px; height: 250px; display: flex; align-items: center; justify-content: center; 
      overflow: hidden; box-shadow: 0 15px 35px rgba(0,0,0,0.5); transition: transform 0.4s ease;
    }
    .acc-card-fixed img { width: 100%; height: 100%; object-fit: cover; }

    .card-1 { transform: rotate(-8deg) translateY(20px); }
    .card-2 { transform: rotate(5deg) translateY(-10px); }
    .card-3 { transform: rotate(-5deg) translateY(15px); }
    .acc-card-fixed:hover { transform: rotate(0deg) scale(1.1); z-index: 10; }

    /* Modal Styles */
    .modal { display: none; position: fixed; z-index: 3000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); }
    .modal-content { background: white; margin: 8% auto; padding: 40px; width: 90%; max-width: 550px; border-radius: 20px; position: relative; text-align: center; }
    .close-modal { position: absolute; right: 20px; top: 15px; font-size: 32px; cursor: pointer; }

    /* Footer */
    footer { padding: 60px 5%; border-top: 1px solid #eee; background: #fafafa; }
    .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 40px; }
    .footer-col h4 { margin-bottom: 15px; font-size: 14px; }
    .footer-col a { display: block; text-decoration: none; color: #666; font-size: 13px; margin-bottom: 8px; }
  </style>

  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</head>
<body>

  <div id="side-menu" class="side-nav">
    <a href="javascript:void(0)" class="closebtn" onclick="toggleMenu()">&times;</a>
    <h3 style="padding: 0 32px;">Categories</h3>
    <hr style="margin: 10px 0;">
    <a href="#">Laptops</a>
    <a href="#">Computer parts</a>
    <a href="#">Smartphones</a>
    <a href="#">Enterprise networking</a>
    <a href="#">Tablets and eBooks</a>
    <a href="#">Storage and media</a>
    <a href="#">Lenses and filters</a>
  </div>
  <div id="overlay" class="overlay" onclick="toggleMenu()"></div>

  <header>
    <div class="header-left">
      <div class="menu-icon" onclick="toggleMenu()">&#9776;</div>
      <div class="logo">My eStore</div>
    </div>
    <div class="search-bar">
      <input type="text" placeholder="Search for gadgets...">
      <button>Search</button>
    </div>
    <nav class="top-nav">
      <a href="#">Saved</a>
      <a href="#">Electronics</a>
      <a href="#">Motors</a>
      <a href="#">Cart</a>
    </nav>
  </header>

  <div class="hero">
    <div class="hero-text">
      <h1>Don't miss out on insider perks</h1>
      <p>What are you waiting for? Make the most of your account benefits.</p>
      <button class="sign-in-btn">Sign In</button>
    </div>
  </div>

  <section class="categories-container">
    <h2 class="section-title">Featured Tech Deals</h2>
    <div id="electronics-deals" class="categories-grid">
      <p>Fetching the latest deals...</p>
    </div>
  </section>

  <section class="categories-container">
    <h2 class="section-title">The future in your hands</h2>
    <div class="categories-grid">
      <div class="category-item">
        <div class="img-box"><img src="images/laptop.jpg" alt="Laptops"></div>
        <p>Laptops</p>
      </div>
      <div class="category-item">
        <div class="img-box"><img src="images/computer parts.jpg" alt="Computer parts"></div>
        <p>Computer parts</p>
      </div>
      <div class="category-item">
        <div class="img-box"><img src="images/smart phones.jpg" alt="Smartphones"></div>
        <p>Smartphones</p>
      </div>
      <div class="category-item">
        <div class="img-box"><img src="images/enterprise networking.jpg" alt="Networking"></div>
        <p>Enterprise networking</p>
      </div>
      <div class="category-item">
        <div class="img-box"><img src="images/tablets and e books.jpg" alt="Tablets"></div>
        <p>Tablets and eBooks</p>
      </div>
      <div class="category-item">
        <div class="img-box"><img src="images/storage and blank media.jpg" alt="Storage"></div>
        <p>Storage and blank media</p>
      </div>
      <div class="category-item">
        <div class="img-box"><img src="images/lenses and filters.jpg" alt="Lenses"></div>
        <p>Lenses and filters</p>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="cta-banner">
      <div class="cta-content">
        <h2>Shopping made easy</h2>
        <p>Enjoy reliability, secure deliveries and hassle-free returns.</p>
      </div>
      <button class="start-now-pill">Start now</button>
    </div>
  </section>

  <section class="accessories-hero">
    <div class="acc-text">
      <h2>Endless gadgets. Epic prices.</h2>
      <p>Browse millions of tech upgrades.</p>
      <button class="shop-now-fixed">Shop now</button>
    </div>
    <div class="acc-images">
      <div class="acc-card-fixed card-1">
        <img src="https://images.unsplash.com/photo-1546054454-aa26e2b734c7?auto=format&fit=crop&q=80&w=300" alt="Gadget 1">
      </div>
      <div class="acc-card-fixed card-2">
        <img src="https://images.unsplash.com/photo-1527443224154-c4a3942d3acf?auto=format&fit=crop&q=80&w=300" alt="Gadget 2">
      </div>
      <div class="acc-card-fixed card-3">
        <img src="https://images.unsplash.com/photo-1591488320449-011701bb6704?auto=format&fit=crop&q=80&w=300" alt="Gadget 3">
      </div>
    </div>
  </section>

  <footer>
    <div class="footer-grid">
      <div class="footer-col">
        <h4>Buy</h4>
        <a href="#">Registration</a>
        <a href="#">Bidding help</a>
      </div>
      <div class="footer-col">
        <h4>Sell</h4>
        <a href="#">Start selling</a>
      </div>
      <div class="footer-col">
        <h4>About</h4>
        <a href="#">Company info</a>
      </div>
      <div class="footer-col">
        <h4>Contact</h4>
        <a href="#">Seller Center</a>
      </div>
    </div>
  </footer>

  <div id="product-modal" class="modal">
    <div class="modal-content">
      <span class="close-modal">&times;</span>
      <div id="modal-body"></div>
    </div>
  </div>

  <script>
    function toggleMenu() {
      const menu = $("#side-menu");
      const overlay = $("#overlay");
      menu.width() === 280 ? (menu.width(0), overlay.hide()) : (menu.width(280), overlay.show());
    }1

    $(document).ready(function() {
      // Dynamic Deal Fetching
      $.get("https://fakestoreapi.com/products/category/electronics", function(products) {
        const grid = $("#electronics-deals").empty();
        products.slice(0, 4).forEach(p => {
          grid.append(`
            <div class="category-item dynamic-card">
              <div class="img-box"><img src="${p.image}"></div>
              <p class="product-price">$${p.price}</p>
              <button class="quick-view-btn" data-id="${p.id}">Quick View</button>
            </div>
          `);
        });
      });

      // Quick View Logic
      $(document).on("click", ".quick-view-btn", function() {
        const id = $(this).data("id");
        $.get(`https://fakestoreapi.com/products/${id}`, function(data) {
          $("#modal-body").html(`
            <img src="${data.image}" style="width:150px; margin-bottom:10px;">
            <h3>${data.title}</h3>
            <p style="margin: 10px 0;">${data.description.substring(0,100)}...</p>
            <h4 style="color:#0066ff;">$${data.price}</h4>
          `);
          $("#product-modal").fadeIn();
        });
      });

      $(".close-modal").click(() => $("#product-modal").fadeOut());
    });
  </script>
</body>
</html>